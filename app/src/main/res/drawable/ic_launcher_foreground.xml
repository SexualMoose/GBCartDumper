<!--
  Launcher-icon foreground.

  Minimalist "classic save-icon floppy disk dissolving into data".
  Upper two-thirds is a clean floppy silhouette with its trademark shutter
  chamfer; the lower third is the floppy's data cascading off the bottom
  edge as matrix-style falling bits (a tapering 3dp-pixel grid).

  Layout (108 dp viewport, 66 dp adaptive-icon safe zone = y 21..87):
    Floppy body      :  x 28..80, y 24..60     (52 × 36, centred)
    Shutter inset    :  x 34..66, y 24..33
    Label inset      :  x 34..74, y 42..56
    Matrix pixels    :  y 62..83, 4 rows of 3 dp squares, thinning downward

  Even buffer inside the safe zone:
    top 3 dp · bottom 4 dp · left 7 dp · right 7 dp

  Two colours only (green + dark-surface cutouts) so the OS's monochrome
  themed-icon pass collapses cleanly to a single tint.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Floppy body silhouette with the shutter-corner chamfer on top-right. -->
    <path
        android:fillColor="#9CCC65"
        android:pathData="M 28,24 L 74,24 L 80,30 L 80,60 L 28,60 Z" />

    <!-- Metal shutter: dark inset across the top of the body. -->
    <path
        android:fillColor="#0B0E13"
        android:pathData="M 34,24 L 66,24 L 66,33 L 34,33 Z" />

    <!-- Paper label: dark inset panel in the middle of the body. -->
    <path
        android:fillColor="#0B0E13"
        android:pathData="M 34,42 L 74,42 L 74,56 L 34,56 Z" />

    <!-- Matrix dissolve — four rows of 3 dp pixels tapering downward, so the
         floppy's contents read as "falling into a bit-stream". -->
    <path
        android:fillColor="#9CCC65"
        android:pathData="
            M 30,62 h3 v3 h-3 z
            M 40,62 h3 v3 h-3 z
            M 52,62 h3 v3 h-3 z
            M 64,62 h3 v3 h-3 z
            M 74,62 h3 v3 h-3 z
            M 28,68 h3 v3 h-3 z
            M 38,68 h3 v3 h-3 z
            M 50,68 h3 v3 h-3 z
            M 62,68 h3 v3 h-3 z
            M 72,68 h3 v3 h-3 z
            M 34,74 h3 v3 h-3 z
            M 46,74 h3 v3 h-3 z
            M 58,74 h3 v3 h-3 z
            M 70,74 h3 v3 h-3 z
            M 40,80 h3 v3 h-3 z
            M 54,80 h3 v3 h-3 z
            M 66,80 h3 v3 h-3 z" />
</vector>
